              "notes": "Read operand from ACC"
            },
            {
              "step": 2,
              "ip_block": "acc_adder",
              "direction": "compute",
              "notes": "Negate + add"
            },
            {
              "step": 3,
              "ip_block": "acc_write_port",
              "direction": "write",
              "notes": "Write result to ACC"
            }
          ],
          "cost_tag": "onchip_compute",
          "cost_formula_hint": "elements * acc_op_latency",
          "gemmini_rationale": "Same acc adder units as add; negate + accumulate."
        },
        {
          "realization_id": "standalone_rocket",
          "is_default": true,
          "condition": "general elementwise subtract",
          "ip_flow": [
            {
              "step": 1,
              "ip_block": "rocket_core",
              "direction": "compute",
              "notes": "Host CPU scalar/vector library loop"
            }
          ],
          "cost_tag": "host_fallback",
          "cost_formula_hint": "elements * rocket_per_elem_cycles",
          "gemmini_rationale": "Rocket core library."
        }
      ]
    },
    "multiply": {
      "realizations": [
        {
          "realization_id": "standalone_rocket",
          "is_default": true,
