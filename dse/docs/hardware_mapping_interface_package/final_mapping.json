{
  "version": 3,
  "model": "realization_first",
  "description": "Each TAIDL/XLA primitive maps to one or more realizations. Each realization maps to an ordered IP flow and a cost tag. Fused patterns override individual per-op mappings.",
  "pipeline_stages": [
    "1. Semantics: TAIDL/XLA meaning",
    "2. Primitive decomposition",
    "3. Normalization (canonical op names)",
    "4. Fusion check (fused_patterns, highest priority first)",
    "5. Per-op realization selection (default unless condition selects alternative)",
    "6. IP flow assignment",
    "7. Cost aggregation via cost_tag"
  ],
  "primitives": {
    "dot": {
      "realizations": [
        {
          "realization_id": "systolic_gemm",
          "is_default": true,
          "condition": "standard matmul; operands fit in SPAD",
          "ip_flow": [
            {
              "step": 1,
              "ip_block": "spad_read_port",
              "direction": "read",
              "notes": "SPAD \u2192 mesh input mux (LHS rows)"
            },
            {
              "step": 2,
              "ip_block": "spad_read_port",
              "direction": "read",
              "notes": "SPAD \u2192 mesh input mux (RHS cols)"
            },
            {
              "step": 3,
              "ip_block": "systolic_mesh",
              "direction": "compute",
              "notes": "DIM\u00d7DIM PE array; WS or OS dataflow"
            },
            {
              "step": 4,
              "ip_block": "acc_write_port",
              "direction": "write",
              "notes": "Mesh output \u2192 AccumulatorMem"
            }
          ],
          "cost_tag": "tensor_compute",
          "cost_formula_hint": "MACs / peak_mac_throughput",
          "gemmini_rationale": "config_ex + matmul.preload + matmul.compute; result in ACC."
        },
        {
          "realization_id": "systolic_gemm_transposed",
          "is_default": false,
          "condition": "one operand requires transpose",
          "ip_flow": [
            {
              "step": 1,
              "ip_block": "spad_read_port",
              "direction": "read",
              "notes": "SPAD \u2192 transposer input"
            },
            {
              "step": 2,
              "ip_block": "transposer",
              "direction": "compute",
              "notes": "On-chip transpose unit inside ExecuteController"
            },
            {
              "step": 3,
              "ip_block": "systolic_mesh",
              "direction": "compute",
              "notes": "Transposed data feeds mesh"
            },
            {
              "step": 4,
              "ip_block": "acc_write_port",
              "direction": "write",
              "notes": "Mesh output \u2192 AccumulatorMem"
            }
          ],
          "cost_tag": "tensor_compute",
          "cost_formula_hint": "MACs / peak_mac_throughput",
          "gemmini_rationale": "Same execute path but config_ex transpose bits set; on-chip transposer feeds mesh."
        },
        {
          "realization_id": "loop_ws_tiled",
          "is_default": false,
          "condition": "tile larger than DIM; compiler emits CISC",
          "ip_flow": [
            {
              "step": 1,
              "ip_block": "dma_engine",
              "direction": "read",
              "notes": "DRAM \u2192 SPAD double-buffered tiles"
            },
            {
              "step": 2,
              "ip_block": "loop_unroller_fsm",
              "direction": "control",
              "notes": "CISC gemmini_loop_ws FSM"
            },
            {
              "step": 3,
              "ip_block": "spad_read_port",
              "direction": "read",
              "notes": "SPAD rows/cols to mesh"
            },
            {
              "step": 4,
              "ip_block": "systolic_mesh",
              "direction": "compute",
              "notes": "Tile computation"
            },
            {
              "step": 5,
              "ip_block": "acc_write_port",
              "direction": "write",
              "notes": "Partial sums to ACC"
            },
            {
              "step": 6,
              "ip_block": "dma_engine",
              "direction": "write",
              "notes": "ACC \u2192 DRAM (final tiles)"
            }
          ],
          "cost_tag": "tensor_compute_tiled",
          "cost_formula_hint": "tile_passes * per_tile_cost + dma_overhead",
          "gemmini_rationale": "gemmini_loop_ws: FSM handles double-buffered tiling automatically."
        }
      ]
    },
    "add": {
      "realizations": [
        {
          "realization_id": "fused_bias_in_matmul",
          "is_default": false,
          "condition": "add is fused as D operand in OS matmul",
          "ip_flow": [
            {
              "step": 1,
              "ip_block": "none",
              "direction": "absorbed",
              "notes": "Folded into matmul.preload D operand; no separate IP"
            }
          ],
          "cost_tag": "zero_cost",
          "cost_formula_hint": "0",
          "gemmini_rationale": "No separate IP; add absorbed into matmul.preload D preload. Cost folded into dot."
        },
        {
          "realization_id": "acc_accumulate",
          "is_default": false,
          "condition": "operand in ACC; in-place accumulation",
          "ip_flow": [
            {
              "step": 1,
              "ip_block": "acc_read_port",
              "direction": "read",
              "notes": "Read current ACC value"
            },
            {
              "step": 2,
              "ip_block": "acc_adder",
              "direction": "compute",
              "notes": "ACC internal adder"
            },
            {
              "step": 3,
              "ip_block": "acc_write_port",
              "direction": "write",
              "notes": "Write accumulated result"
            }
          ],
          "cost_tag": "onchip_compute",
          "cost_formula_hint": "elements * acc_op_latency",
          "gemmini_rationale": "ACC write with accumulate bit set (bit 30 of acc address). Uses acc adder units."
        },
        {
          "realization_id": "standalone_rocket",
          "is_default": true,
          "condition": "general elementwise add; no fusion matched",
          "ip_flow": [
            {
              "step": 1,
              "ip_block": "rocket_core",
              "direction": "compute",
              "notes": "Host CPU scalar/vector library loop"
            }
          ],
          "cost_tag": "host_fallback",
          "cost_formula_hint": "elements * rocket_per_elem_cycles",
          "gemmini_rationale": "Rocket core library loop over SPAD/ACC data."
        }
      ]
    },
    "subtract": {
      "realizations": [
        {
          "realization_id": "acc_path",
          "is_default": false,
          "condition": "operand in ACC; same adder family as add",
          "ip_flow": [
